<?xml version="1.0" encoding="utf-8"?>
<!--
  pt-rPT quantity strings. Portuguese uses one + other.
  Each <item> uses %1$d so callers pass (count, count) to pluralStringResource.
-->
<resources>

    <!-- Upload banner running count: "1 foto adicionada" / "3 fotos adicionadas". -->
    <plurals name="photos_added">
        <item quantity="one">%1$d foto adicionada</item>
        <item quantity="other">%1$d fotos adicionadas</item>
    </plurals>

    <!-- Library multi-select count: "2 selecionadas". -->
    <plurals name="selected_count">
        <item quantity="one">%1$d selecionado</item>
        <item quantity="other">%1$d selecionados</item>
    </plurals>

    <!-- Album photo count subtitle: "12 fotos". -->
    <plurals name="album_photos">
        <item quantity="one">%1$d foto</item>
        <item quantity="other">%1$d fotos</item>
    </plurals>

</resources>

<?xml version="1.0" encoding="utf-8"?>
<!--
  Quantity strings. en uses only one/other; translations add few/many where the
  language requires (Russian and Polish: one/few/many/other). Each <item> must use
  %1$d for the count so callers pass (count, count) to pluralStringResource.
-->
<resources>

    <!-- Upload banner running count: "1 photo added" / "3 photos added". -->
    <plurals name="photos_added">
        <item quantity="one">%1$d photo added</item>
        <item quantity="other">%1$d photos added</item>
    </plurals>

    <!-- Library multi-select count: "2 selected". -->
    <plurals name="selected_count">
        <item quantity="one">%1$d selected</item>
        <item quantity="other">%1$d selected</item>
    </plurals>

    <!-- Album photo count subtitle: "12 photos". -->
    <plurals name="album_photos">
        <item quantity="one">%1$d photo</item>
        <item quantity="other">%1$d photos</item>
    </plurals>

</resources>
